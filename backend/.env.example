# ── 데이터베이스 ──────────────────────────────────────────────────
# asyncpg 드라이버 사용 (FastAPI 비동기)
DATABASE_URL=postgresql+asyncpg://lol_user:password@localhost:5432/lol_coach

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── 인증 (최소 32자 랜덤 문자열) ─────────────────────────────────
# 생성 방법: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# ── AWS (S3 .rofl 임시 저장) ─────────────────────────────────────
AWS_S3_BUCKET=lol-coach-replays
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ── Riot API ──────────────────────────────────────────────────────
# https://developer.riotgames.com 에서 발급
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── LLM (Anthropic Claude) ────────────────────────────────────────
LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=claude-sonnet-4-6

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── 환경 ──────────────────────────────────────────────────────────
ENVIRONMENT=development
2